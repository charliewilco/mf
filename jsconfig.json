{
	"compilerOptions": {
		"target": "ES2024",
		"lib": ["ES2024"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"types": ["node"],
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"noImplicitAny": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true
	},
	"include": ["*.js"],
	"exclude": ["dist", "node_modules"]
}
